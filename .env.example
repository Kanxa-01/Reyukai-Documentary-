# Copy this file to .env and fill in your real values. Never commit .env.

# Get this from your Neon project dashboard -> Connection Details
# Looks like: postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@your-neon-host/dbname?sslmode=require

# Any long random string — used to sign session cookies
SECRET_KEY=change-this-to-a-random-string
